{
  "name": "veris",
  "version": "0.1.0",
  "description": "Local-first, OpenAI-compatible LLM gateway with a smart router across 11 providers. Bring your own API key.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "llm",
    "gateway",
    "openai",
    "openai-compatible",
    "router",
    "anthropic",
    "gemini",
    "groq",
    "ollama",
    "proxy",
    "ai",
    "byok",
    "local-first"
  ],
  "homepage": "https://github.com/anderamondarainh-stack/veris#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anderamondarainh-stack/veris.git"
  },
  "bugs": {
    "url": "https://github.com/anderamondarainh-stack/veris/issues"
  },
  "bin": {
    "veris": "bin/veris.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {

# =============================================================================
# Veris — configuración de ejemplo. Copia este fichero a `.env` y ajusta.
# Todas las variables son OPCIONALES, pero necesitas al menos una API key
# (o activar Ollama) para que haya algún provider disponible.
# =============================================================================

# -----------------------------------------------------------------------------
# Gateway
# -----------------------------------------------------------------------------
# Puerto del servidor local.
PORT=8787
# Estrategia del router: cheapest | best | balanced.
ROUTER_STRATEGY=balanced
# Si se define, el gateway exige `Authorization: Bearer <clave>`.
# Protege tu gateway local de que otra cosa en tu máquina lo use.
BYOA_GATEWAY_KEY=
# Reintentos ante errores transitorios (429/5xx).
BYOA_MAX_RETRIES=2
# Base del backoff exponencial entre reintentos (ms).
BYOA_RETRY_BASE_MS=250
# Activa el fallback automático a otro modelo si uno falla.
BYOA_FALLBACK=true
# TTL en segundos de la caché de respuestas idénticas. 0 = desactivada.
BYOA_CACHE_TTL=0
# Tope de gasto acumulado en USD. Si se supera, las peticiones responden 402.
# 0 = sin tope.
BYOA_SPEND_CAP_USD=0
# Fichero JSON opcional para añadir/corregir modelos del catálogo.
MODELS_FILE=
# Observabilidad: logging estructurado de peticiones.
BYOA_LOG=true
# Observabilidad: expone métricas Prometheus en /metrics.
BYOA_METRICS=true

# -----------------------------------------------------------------------------
# Providers BYOK (API keys oficiales)
# -----------------------------------------------------------------------------
# NOTA multi-key: cualquiera de estas variables admite VARIAS keys separadas
# por comas; el provider rota entre ellas (round-robin) para repartir límites.
# Ej.: OPENAI_API_KEY=sk-aaa,sk-bbb,sk-ccc

# OpenAI (también acepta override de base URL con OPENAI_BASE_URL).
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# Anthropic.
ANTHROPIC_API_KEY=
# Google Gemini.
GEMINI_API_KEY=

# --- Otros proveedores OpenAI-compatible ---
# Groq.
GROQ_API_KEY=
# DeepSeek.
DEEPSEEK_API_KEY=
# Mistral.
MISTRAL_API_KEY=
# xAI (Grok).
XAI_API_KEY=
# Together AI.
TOGETHER_API_KEY=
# Perplexity.
PERPLEXITY_API_KEY=
# OpenRouter.
OPENROUTER_API_KEY=

# -----------------------------------------------------------------------------
# Ollama (modelos locales, sin coste ni API key)
# -----------------------------------------------------------------------------
# Activa Ollama con cualquiera de las dos vías:
#   - OLLAMA_ENABLED=true  (usa la base URL por defecto http://localhost:11434/v1)
#   - o define OLLAMA_BASE_URL (la activa automáticamente, p. ej. en Docker)
OLLAMA_ENABLED=false
# OLLAMA_BASE_URL=http://localhost:11434/v1

# -----------------------------------------------------------------------------
# Account-provider (zona gris ToS · opcional · DESACTIVADO por defecto)
# Lee el DISCLAIMER.md antes de activarlo. Viola los ToS de terceros.
# -----------------------------------------------------------------------------
ACCOUNT_PROVIDER_ENABLED=false
# Carpeta local del perfil de navegador (cookies/sesión).
BYOA_PROFILE_DIR=.browser-profiles
# Clave maestra para cifrar credenciales en disco (AES-256-GCM).
BYOA_MASTER_KEY=
# Ejecuta el navegador sin interfaz gráfica.
ACCOUNT_HEADLESS=false
# Imita la cadencia humana al teclear.
ACCOUNT_HUMANIZE=true
# Aplica medidas anti-detección al navegador.
ACCOUNT_STEALTH=false

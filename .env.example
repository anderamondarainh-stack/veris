# ─── byoa-gateway · configuración ────────────────────────────────────────
# Copia este archivo a .env y rellena solo lo que vayas a usar.
# NADA de esto sale de tu máquina: el gateway corre 100% local (local-first).

# Puerto del gateway local
PORT=8787

# Clave maestra para cifrar las credenciales en disco (.byoa/creds.enc).
# Si la dejas vacía, se deriva de la máquina (menos seguro pero cómodo).
BYOA_MASTER_KEY=

# ─── Providers BYOK (Bring Your Own Key) — el camino limpio ───────────────
# Pon solo las que tengas. El router usará las disponibles.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ─── Router ───────────────────────────────────────────────────────────────
# Estrategia por defecto: cheapest | best | balanced
ROUTER_STRATEGY=balanced

# ─── Resiliencia ────────────────────────────────────────────────────────────
BYOA_FALLBACK=true          # probar el siguiente modelo si uno falla
BYOA_MAX_RETRIES=2          # reintentos por modelo (con backoff)
BYOA_RETRY_BASE_MS=250
BYOA_CACHE_TTL=0            # segundos; 0 = caché desactivada

# ─── Seguridad del gateway ──────────────────────────────────────────────────
# Si lo defines, exige Authorization: Bearer <clave> en /v1/*.
BYOA_GATEWAY_KEY=


# ─── Account provider (zona gris ToS) — OPCIONAL, desactivado por defecto ──
# Úsalo bajo TU responsabilidad. Viola los ToS de los proveedores.
# Requiere Playwright:  npm install playwright && npx playwright install chromium
# Si lo activas, el perfil del navegador (cookies/sesión) vive solo en local.
ACCOUNT_PROVIDER_ENABLED=false
BYOA_PROFILE_DIR=.browser-profiles   # dónde viven los perfiles persistentes
ACCOUNT_HEADLESS=false               # headful es menos detectable
ACCOUNT_HUMANIZE=true                # teclear con cadencia humana (reduce L5)
ACCOUNT_STEALTH=false                # usar playwright-extra stealth si está instalado
